<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Windows 11 Dark Theme -->
    <style name="Theme.Zapret2" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Mica-like dark background -->
        <item name="android:colorBackground">#202020</item>
        <item name="colorSurface">#2D2D2D</item>
        <item name="colorSurfaceVariant">#383838</item>

        <!-- Windows 11 accent (blue) -->
        <item name="colorPrimary">#60CDFF</item>
        <item name="colorPrimaryContainer">#0078D4</item>
        <item name="colorOnPrimary">#000000</item>

        <!-- Secondary -->
        <item name="colorSecondary">#96D6FF</item>
        <item name="colorOnSecondary">#000000</item>

        <!-- Error -->
        <item name="colorError">#FF6B6B</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">#1A1A1A</item>
        <item name="android:navigationBarColor">#1A1A1A</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Ripple -->
        <item name="colorControlHighlight">#3360CDFF</item>

        <!-- Dialog -->
        <item name="materialAlertDialogTheme">@style/MaterialAlertDialog.Zapret2</item>
    </style>

    <!-- Bottom Sheet Theme -->
    <style name="Theme.Zapret2.BottomSheet" parent="Theme.Material3.Dark.BottomSheetDialog">
        <item name="android:colorBackground">#2D2D2D</item>
        <item name="colorSurface">#2D2D2D</item>
        <item name="bottomSheetStyle">@style/Widget.Zapret2.BottomSheet</item>
        <item name="android:navigationBarColor">#2D2D2D</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="Widget.Zapret2.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="backgroundTint">#2D2D2D</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Zapret2.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.Zapret2.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- Card style -->
    <style name="Widget.Zapret2.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">#2D2D2D</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">#3D3D3D</item>
    </style>

    <!-- Button style -->
    <style name="Widget.Zapret2.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">4dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="Widget.Zapret2.Button.Accent">
        <item name="backgroundTint">#0078D4</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.Zapret2.Button.Secondary">
        <item name="backgroundTint">#383838</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.Zapret2.Button.Success">
        <item name="backgroundTint">#107C10</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="Widget.Zapret2.Button.Danger">
        <item name="backgroundTint">#D13438</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <!-- Toolbar style -->
    <style name="Widget.Zapret2.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">#1A1A1A</item>
        <item name="titleTextColor">#FFFFFF</item>
        <item name="navigationIconTint">#FFFFFF</item>
    </style>

    <!-- Navigation Drawer style -->
    <style name="Widget.Zapret2.NavigationView" parent="Widget.Material3.NavigationView">
        <item name="android:background">#2D2D2D</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="itemShapeFillColor">@color/nav_item_background</item>
    </style>

    <!-- BottomSheet Dialog Theme for fragments -->
    <style name="BottomSheetDialogTheme" parent="Theme.Material3.Dark.BottomSheetDialog">
        <item name="android:colorBackground">#2D2D2D</item>
        <item name="colorSurface">#2D2D2D</item>
        <item name="bottomSheetStyle">@style/Widget.Zapret2.BottomSheet</item>
        <item name="android:navigationBarColor">#2D2D2D</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <!-- Typography Scale -->
    <style name="TextAppearance.Zapret2.SectionHeader" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Zapret2.RowTitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Zapret2.RowValue" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.Zapret2.RowSubtitle" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_tertiary</item>
    </style>

    <style name="TextAppearance.Zapret2.Monospace" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Dialog Theme -->
    <style name="MaterialAlertDialog.Zapret2" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.Zapret2.RowTitle</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Zapret2.Dialog</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.Zapret2.Button.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.Zapret2.Button.Dialog</item>
    </style>

    <style name="ShapeAppearance.Zapret2.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="Widget.Zapret2.Button.Dialog" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/accent_light</item>
    </style>
</resources>
