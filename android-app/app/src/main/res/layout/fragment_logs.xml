<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- Tab Layout: Command / Logs / Errors -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutLogs"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/background_primary"
        app:tabIndicatorColor="@color/accent_primary"
        app:tabIndicatorHeight="2dp"
        app:tabSelectedTextColor="@color/text_primary"
        app:tabTextColor="@color/text_tertiary"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabRippleColor="@color/ripple_accent">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Command" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logs" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Errors" />

    </com.google.android.material.tabs.TabLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_strong" />

    <!-- Command Tab Content -->
    <FrameLayout
        android:id="@+id/cmdlineContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="visible">

        <com.zapret2.app.NestedScrollableHost
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:scrollbars="vertical"
                android:fadeScrollbars="false"
                android:background="@color/background_darker"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Command Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Current Command Line"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iconCopyCmdline"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_copy"
                            app:tint="@color/text_tertiary"
                            android:padding="4dp"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Copy command line" />

                    </LinearLayout>

                    <!-- Formatted Command Text -->
                    <TextView
                        android:id="@+id/textCmdline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No command line available"
                        android:textColor="@color/text_command"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:lineSpacingExtra="4dp"
                        android:textIsSelectable="true" />

                </LinearLayout>

            </ScrollView>

        </com.zapret2.app.NestedScrollableHost>

    </FrameLayout>

    <!-- Logs Tab Content -->
    <LinearLayout
        android:id="@+id/logsContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Log Filter Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:background="@color/background_primary">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                app:boxStrokeColor="@color/border_strong"
                app:boxStrokeWidth="1dp"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editLogFilter"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Filter logs..."
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_tertiary"
                    android:textSize="13sp"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@android:color/transparent" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/checkAutoScroll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:checked="true"
                app:buttonTint="@color/accent_primary"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <!-- Log Content Area -->
        <com.zapret2.app.NestedScrollableHost
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ScrollView
                android:id="@+id/scrollLogs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:scrollbars="vertical"
                android:fadeScrollbars="false"
                android:background="@color/background_darker"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/textLogs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading logs..."
                    android:textColor="@color/text_log"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="2dp"
                    android:padding="12dp"
                    android:textIsSelectable="true" />

            </ScrollView>

        </com.zapret2.app.NestedScrollableHost>

    </LinearLayout>

    <!-- Bottom Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:gravity="center"
        android:background="@color/background_primary">

        <!-- Refresh Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRefresh"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Refresh"
            android:textSize="13sp"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="8dp"
            app:strokeColor="@color/border_strong"
            app:strokeWidth="1dp"
            android:textColor="@color/text_primary"
            app:icon="@drawable/ic_refresh"
            app:iconGravity="textStart"
            app:iconTint="@color/text_primary"
            app:iconPadding="4dp"
            app:iconSize="18dp" />

        <!-- Copy Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCopyLogs"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:text="Copy"
            android:textSize="13sp"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="8dp"
            app:strokeColor="@color/border_strong"
            app:strokeWidth="1dp"
            android:textColor="@color/text_primary"
            app:icon="@drawable/ic_copy"
            app:iconGravity="textStart"
            app:iconTint="@color/text_primary"
            app:iconPadding="4dp"
            app:iconSize="18dp" />

        <!-- Clear Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonClearLogs"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Clear"
            android:textSize="13sp"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="8dp"
            app:strokeColor="@color/status_error"
            app:strokeWidth="1dp"
            android:textColor="@color/status_error"
            app:icon="@drawable/ic_delete"
            app:iconGravity="textStart"
            app:iconTint="@color/status_error"
            app:iconPadding="4dp"
            app:iconSize="18dp" />

    </LinearLayout>

</LinearLayout>
