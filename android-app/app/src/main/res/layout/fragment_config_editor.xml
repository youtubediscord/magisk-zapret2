<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="nfqws2 command line"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textCommandFilePath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="/data/adb/modules/zapret2/zapret2/cmdline.txt"
        android:textColor="@color/text_tertiary"
        android:textSize="11sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="10dp"
        android:text="Edit nfqws2 options passed at startup. You can use one option per line for readability."
        android:textColor="@color/text_tertiary"
        android:textSize="11sp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/accent_primary"
        app:hintTextColor="@color/accent_light"
        android:hint="nfqws2 command line">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editCommandLine"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:gravity="top|start"
            android:inputType="textMultiLine|textNoSuggestions|textVisiblePassword"
            android:overScrollMode="ifContentScrolls"
            android:scrollbars="vertical"
            android:padding="12dp"
            android:hint="--new --filter-tcp=443 --payload=tls_client_hello ..." />

    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonReloadCommand"
            style="@style/Widget.Zapret2.Button"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Reload"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/surface_variant"
            app:icon="@drawable/ic_refresh"
            app:iconGravity="textStart"
            app:iconTint="@color/text_primary"
            app:iconSize="18dp"
            app:iconPadding="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSaveCommand"
            style="@style/Widget.Zapret2.Button"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:text="Save"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/accent_primary"
            app:icon="@drawable/ic_save"
            app:iconGravity="textStart"
            app:iconTint="@color/text_primary"
            app:iconSize="18dp"
            app:iconPadding="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSaveRestartCommand"
            style="@style/Widget.Zapret2.Button"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Save + Restart"
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/button_save_restart"
            app:icon="@drawable/ic_control"
            app:iconGravity="textStart"
            app:iconTint="@color/text_primary"
            app:iconSize="18dp"
            app:iconPadding="4dp" />

    </LinearLayout>

</LinearLayout>
