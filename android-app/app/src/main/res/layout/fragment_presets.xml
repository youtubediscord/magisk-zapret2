<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#202020">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="vertical"
        android:scrollbarAlwaysDrawVerticalTrack="true"
        android:fadeScrollbars="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active Runtime Mode"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/setting_row_background">

                <TextView
                    android:id="@+id/textActiveModeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Categories mode"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textActivePresetValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="categories.ini + strategies-*.ini"
                    android:textColor="#C8C8C8"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp" />

                <TextView
                    android:id="@+id/textPresetsPath"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/data/adb/modules/zapret2/zapret2/presets"
                    android:textColor="#808080"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonReloadPresets"
                        style="@style/Widget.Zapret2.Button"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Reload"
                        android:textSize="12sp"
                        android:backgroundTint="#383838"
                        android:textColor="#FFFFFF" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonUseCategories"
                        style="@style/Widget.Zapret2.Button"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Use Categories"
                        android:textSize="12sp"
                        android:backgroundTint="#0078D4"
                        android:textColor="#FFFFFF" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preset Files"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Presets are plain .txt files in module folder. You can edit them directly or from this screen."
                android:textColor="#808080"
                android:textSize="12sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/presetListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/textNoPresets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No preset files found"
                android:textColor="#888888"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingVertical="24dp"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>

    </ScrollView>

    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC202020"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="#0078D4" />

            <TextView
                android:id="@+id/loadingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="16dp" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
